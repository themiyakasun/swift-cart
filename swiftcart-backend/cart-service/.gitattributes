# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.java text diff=java
*.xml text diff=xml
*.properties text
*.yml text
*.yaml text

# Shell scripts
*.sh text eol=lf
mvnw text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
mvnw.cmd text eol=crlf

# Documentation
*.md text
*.txt text

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.gz binary

# Other
*.pdf binary
